// Seleciona o formulário e a mensagem de confirmação
const form = document.getElementById('form-contato');
const mensagemConfirmacao = document.getElementById('mensagem-confirmacao');

// Adiciona evento de envio
form.addEventListener('submit', function(e) {
    e.preventDefault(); // Evita reload da página

    // Aqui você pode integrar com um backend ou serviço de e-mail
    // Por enquanto, apenas mostramos a mensagem de confirmação
    mensagemConfirmacao.classList.remove('hidden');

    // Limpa o formulário
    form.reset();

    // Opcional: esconder a mensagem após 5 segundos
    setTimeout(() => {
        mensagemConfirmacao.classList.add('hidden');
    }, 5000);
});

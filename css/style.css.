/* RESET BÁSICO */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* BODY */
body {
    background-color: #f4f4f9;
    color: #333;
    line-height: 1.6;
    scroll-behavior: smooth;
}

/* HEADER / MENU */
header {
    background-color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    position: sticky;
    top: 0;
    z-index: 1000;
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 1200px;
    margin: auto;
}

nav .logo {
    font-size: 1.6rem;
    font-weight: bold;
    color: #FF6600; /* símbolo do coração laranja */
    cursor: pointer;
}

nav ul.menu {
    list-style: none;
    display: flex;
    gap: 2rem;
}

nav ul.menu li a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
    transition: color 0.3s, transform 0.3s;
}

nav ul.menu li a:hover {
    color: #FF6600;
    transform: scale(1.05);
}

/* SEÇÕES */
section {
    padding: 5rem 2rem;
    max-width: 1200px;
    margin: auto;
}

section h1, section h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: #FF6600;
}

section p {
    max-width: 800px;
    margin: auto;
    text-align: center;
    font-size: 1.1rem;
}

/* PROJETOS */
.projetos-container {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: center;
}

.projeto {
    background-color: #fff;
    padding: 2rem;
    border-radius: 15px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    flex: 1 1 280px;
    max-width: 320px;
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
}

.projeto:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.15);
}

.projeto h3 {
    margin-bottom: 1rem;
    color: #FF6600;
}

.projeto p {
    font-size: 0.95rem;
    color: #555;
}

.projeto a {
    display: inline-block;
    margin-top: 1.5rem;
    text-decoration: none;
    background-color: #FF6600;
    color: #fff;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-weight: bold;
    transition: background-color 0.3s, transform 0.3s;
}

.projeto a:hover {
    background-color: #e65500;
    transform: scale(1.05);
}

/* FORMULÁRIO DE CONTATO */
form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 500px;
    margin: auto;
}

input, textarea {
    padding: 0.9rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    font-size: 1rem;
    width: 100%;
    resize: none;
    transition: border-color 0.3s, box-shadow 0.3s;
}

input:focus, textarea:focus {
    outline: none;
    border-color: #FF6600;
    box-shadow: 0 0 8px rgba(255,102,0,0.3);
}

button {
    padding: 0.9rem;
    border: none;
    border-radius: 8px;
    background-color: #FF6600;
    color: #fff;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s;
}

button:hover {
    background-color: #e65500;
    transform: scale(1.02);
}

/* MENSAGEM DE CONFIRMAÇÃO */
.hidden {
    display: none;
}

#mensagem-confirmacao {
    margin-top: 1rem;
    text-align: center;
    color: green;
    font-weight: bold;
    font-size: 1.1rem;
}

/* RODAPÉ */
footer {
    text-align: center;
    padding: 2rem;
    background-color: #fff;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
    margin-top: 4rem;
    font-size: 0.95rem;
}

/* RESPONSIVO */
@media(max-width:768px) {
    nav ul.menu {
        flex-direction: column;
        gap: 1rem;
    }
    .projetos-container {
        flex-direction: column;
        align-items: center;
    }
}
